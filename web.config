<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- index.php 기본 문서 등록 → /SHVQ_V2/ 로 접근 가능 -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- 민감 파일 직접 접근 차단 -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="config" />
          <add segment="dist_library" />
          <add segment="cron" />
          <add segment="scripts" />
          <add segment="node" />
        </hiddenSegments>
        <filteringRules>
          <filteringRule name="BlockDotFiles" scanUrl="true" scanQueryString="false">
            <appliesTo>
              <add fileExtension=".env" />
              <add fileExtension=".sql" />
            </appliesTo>
            <denyStrings>
              <add string="." />
            </denyStrings>
          </filteringRule>
        </filteringRules>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

  </system.webServer>

  <!-- config/ 디렉토리 직접 접근 금지 -->
  <location path="config">
    <system.webServer>
      <security>
        <requestFiltering>
          <denyAllRequests />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>

  <!-- dist_library/ 직접 접근 금지 -->
  <location path="dist_library">
    <system.webServer>
      <security>
        <requestFiltering>
          <denyAllRequests />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>

  <!-- cron/ 직접 접근 금지 -->
  <location path="cron">
    <system.webServer>
      <security>
        <requestFiltering>
          <denyAllRequests />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>

  <!-- scripts/ 직접 접근 금지 -->
  <location path="scripts">
    <system.webServer>
      <security>
        <requestFiltering>
          <denyAllRequests />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>

</configuration>
